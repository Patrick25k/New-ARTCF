# Copy this file to .env and fill in your values

# Port — Railway sets this automatically, do NOT override it on Railway
PORT=5000

# JWT secret — use a long random string (min 32 chars)
JWT_SECRET=replace-this-with-a-long-random-secret-key-min-32-chars

# Email — use a Gmail App Password (not your regular Gmail password)
# How to get one: https://support.google.com/accounts/answer/185833
EMAIL_USER=artcfr@gmail.com
EMAIL_PASS=your-gmail-app-password-here

# Allowed frontend origins (comma-separated, no trailing slash)
# Add your Vercel URL here once you have it, e.g. https://artcf-website.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://your-project.vercel.app
